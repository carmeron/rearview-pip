# Fastfile for RearViewPiP — cloud build + OTA distribution
# Uses free Apple ID for code signing

default_platform(:ios)

platform :ios do
  desc "Build IPA for development"
  lane :build_and_deploy do
    # Create profiles directory
    sh("mkdir", "-p", "profiles")

    # Get provisioning profile using Apple ID
    # For free accounts, omit team_id — sigh auto-detects it
    profile_opts = {
      development: true,
      force: true,
      username: ENV["APPLE_ID"],
      app_identifier: ENV["APP_BUNDLE_ID"] || "com.rearviewpip.zyl",
      provisioning_name: "RearViewPiP Development",
      output_path: "profiles",
      skip_certificate_verification: true
    }

    # Try with team_name if TEAM_ID is set, otherwise let sigh auto-detect
    if ENV["TEAM_ID"] && !ENV["TEAM_ID"].empty?
      profile_opts[:team_id] = ENV["TEAM_ID"]
    end

    sigh(profile_opts)

    UI.message "🔨 Building IPA..."

    # Build args — only set DEVELOPMENT_TEAM if we have it
    xcargs = ["PROVISIONING_PROFILE_SPECIFIER=RearViewPiP Development"]
    if ENV["TEAM_ID"] && !ENV["TEAM_ID"].empty?
      xcargs << "DEVELOPMENT_TEAM=#{ENV['TEAM_ID']}"
    end

    gym(
      project: "RearViewPiP.xcodeproj",
      scheme: "RearViewPiP",
      export_method: "development",
      output_directory: "build",
      output_name: "RearViewPiP.ipa",
      include_bitcode: false,
      include_symbols: false,
      xcargs: xcargs.join(" ")
    )

    UI.message "✅ IPA built: build/RearViewPiP.ipa"
  end
end
